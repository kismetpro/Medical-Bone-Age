% !TEX root = 1.texS
\usepackage[ruled,vlined]{algorithm2e}

\begin{algorithm}[H]
    \SetKwInOut{Input}{Input}\SetKwInOut{Output}{Output}
    \Input{数据集 $D$, 学习率 $\eta$}
    \Output{模型参数 $w$}
    \BlankLine
    初始化 $w_0$\;
    \For{$t=1, 2, \dots, T$}{
        计算梯度 $g_t = \nabla L(w_{t-1})$\;
        更新参数 $w_t = w_{t-1} - \eta g_t$\;
        \If{$|w_t - w_{t-1}| < \epsilon$}{
            break**\;
        }
    }
    \Return $w_T$\;
    \caption{随机梯度下降算法 (SGD)}
\end{algorithm}